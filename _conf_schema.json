{
  "global_config": {
    "type": "object",
    "description": "全局配置",
    "hint": "鉴权、默认位置和通用请求参数",
    "items": {
      "api_host": {
        "type": "string",
        "description": "和风天气 API Host",
        "hint": "示例：https://xxxxxxxxxx.re.qweatherapi.com",
        "obvious_hint": true,
        "default": ""
      },
      "auth_type": {
        "type": "string",
        "description": "鉴权方式",
        "hint": "建议优先使用 jwt，也可使用 api_key",
        "options": [
          "jwt",
          "api_key"
        ],
        "default": "api_key"
      },
      "api_key": {
        "type": "string",
        "description": "「api_key填写」和风天气 API Key",
        "default": ""
      },
      "jwt_kid": {
        "type": "string",
        "description": "「jwt填写」和风天气 凭据ID",
        "default": ""
      },
      "jwt_project_id": {
        "type": "string",
        "description": "「jwt填写」和风天气 项目ID",
        "default": ""
      },
      "jwt_private_key": {
        "type": "text",
        "description": "「jwt填写」和风天气 私钥 PEM",
        "default": ""
      },
      "jwt_expire_seconds": {
        "type": "int",
        "description": "JWT 过期时间（秒）",
        "hint": "默认 3600；范围 60~86400",
        "default": 3600
      },
      "active_push_sessions": {
        "type": "list",
        "description": "主动消息推送会话列表",
        "hint": "每一项格式：user:个人QQ号 或 group:QQ群号",
        "default": []
      },
      "default_location": {
        "type": "string",
        "description": "默认查询位置",
        "hint": "支持地名、LocationID 或经纬度（如 116.41,39.92）。若要使用分钟级降水功能，请务必填写经纬度。",
        "default": ""
      },
      "geo_range": {
        "type": "string",
        "description": "GeoAPI 搜索范围",
        "hint": "默认 cn（中国），可改为 world，但可能增加误匹配风险",
        "options": [
          "cn",
          "world"
        ],
        "default": "cn"
      },
      "geo_number": {
        "type": "int",
        "description": "GeoAPI 返回候选数量",
        "hint": "默认 10，插件会取第一条作为最佳匹配",
        "default": 10
      }
    }
  },
  "weather_now_config": {
    "type": "object",
    "description": "实时天气相关配置",
    "items": {
      "active_push_enabled": {
        "type": "bool",
        "description": "是否启用实时天气主动消息推送",
        "default": false
      },
      "active_push_interval_minutes": {
        "type": "int",
        "description": "实时天气推送间隔时间（分钟）",
        "hint": "最小 1 分钟",
        "default": 60
      },
      "active_push_start_time": {
        "type": "string",
        "description": "实时天气开始推送时间",
        "hint": "格式 HH:MM，例如 08:00",
        "default": "08:00"
      },
      "weather_fields": {
        "type": "object",
        "description": "实时天气返回指标",
        "hint": "可按需关闭不想展示的指标",
        "items": {
          "match_location": {
            "type": "bool",
            "description": "显示 GeoAPI 命中地点信息",
            "default": true
          },
          "location": {
            "type": "bool",
            "description": "显示地点",
            "default": true
          },
          "weather": {
            "type": "bool",
            "description": "显示天气现象",
            "default": true
          },
          "temperature": {
            "type": "bool",
            "description": "显示温度",
            "default": true
          },
          "feels_like": {
            "type": "bool",
            "description": "显示体感温度",
            "default": true
          },
          "humidity": {
            "type": "bool",
            "description": "显示湿度",
            "default": true
          },
          "wind": {
            "type": "bool",
            "description": "显示风向风速",
            "default": true
          },
          "precip": {
            "type": "bool",
            "description": "显示降水量",
            "default": true
          },
          "pressure": {
            "type": "bool",
            "description": "显示气压",
            "default": true
          },
          "visibility": {
            "type": "bool",
            "description": "显示能见度",
            "default": true
          },
          "obs_time": {
            "type": "bool",
            "description": "显示观测时间",
            "default": true
          },
          "update_time": {
            "type": "bool",
            "description": "显示数据更新时间",
            "default": true
          }
        }
      }
    }
  },
  "forecast_config": {
    "type": "object",
    "description": "天气预报相关配置",
    "items": {
      "active_push_enabled": {
        "type": "bool",
        "description": "是否启用天气预报主动消息推送",
        "default": false
      },
      "active_push_interval_minutes": {
        "type": "int",
        "description": "天气预报推送间隔时间（分钟）",
        "hint": "最小 1 分钟",
        "default": 60
      },
      "active_push_start_time": {
        "type": "string",
        "description": "天气预报开始推送时间",
        "hint": "格式 HH:MM，例如 08:00",
        "default": "08:00"
      },
      "forecast_default_days": {
        "type": "string",
        "description": "天气预报默认天数",
        "options": [
          "3d",
          "7d",
          "10d",
          "15d",
          "30d"
        ],
        "default": "3d"
      }
    }
  },
  "minutely_precip_config": {
    "type": "object",
    "description": "分钟级降水相关配置",
    "items": {
      "active_push_enabled": {
        "type": "bool",
        "description": "是否启用分钟级降水主动消息推送",
        "default": false
      },
      "active_push_interval_minutes": {
        "type": "int",
        "description": "分钟级降水推送间隔时间（分钟）",
        "hint": "最小 1 分钟",
        "default": 60
      },
      "active_push_start_time": {
        "type": "string",
        "description": "分钟级降水开始推送时间",
        "hint": "格式 HH:MM，例如 08:00",
        "default": "08:00"
      },
      "minutely_show_details": {
        "type": "bool",
        "description": "分钟级降水是否显示各时段详细数据",
        "hint": "关闭后仅返回降水概述与更新时间",
        "default": true
      }
    }
  }
}
